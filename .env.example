APP_NAME=Urbania
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8081

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5434
DB_DATABASE=urbania
DB_USERNAME=urbania
DB_PASSWORD=urbania

BROADCAST_CONNECTION=log
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_HOST=localhost
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@urbania.test
MAIL_FROM_NAME="${APP_NAME}"

JWT_PRIVATE_KEY=storage/jwt/private.pem
JWT_PUBLIC_KEY=storage/jwt/public.pem
JWT_ALGORITHM=RS256
JWT_TTL=900
JWT_REFRESH_TTL=1209600
