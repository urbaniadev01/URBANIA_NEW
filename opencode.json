{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "experimental": {
    "bash_default_timeout_ms": 60000
  },
  "mcp": {
    "urbania-db": {
      "type": "local",
      "command": ["powershell", "-NoProfile", "-File", ".opencode/start-db-mcp.ps1"],
      "enabled": true
    },
    "codebase-memory": {
      "type": "local",
      "command": ["codebase-memory-mcp"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  }
}
